{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "electron:compile": {
      "dependsOn": [],
      "inputs": ["electron/src/**/*.ts", "tsconfig.electron.json"],
      "outputs": ["electron/dist/**"]
    },
    "electron:build": {
      "dependsOn": ["build", "electron:compile"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "electron/**"],
      "outputs": ["dist-electron/**"],
      "cache": false
    }
  }
}
