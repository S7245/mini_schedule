<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for Electron's JIT compilation -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Required for certain Node.js native modules -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Disable library validation to allow dynamically-linked frameworks -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Network access for connecting to the backend API -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Allow binding to local port (Next.js standalone server) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- System notifications -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
  </dict>
</plist>
